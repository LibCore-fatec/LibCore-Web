{
  "openapi": "3.0.3",
  "info": {
    "title": "API LibCore",
    "version": "1.0.0",
    "description": "API REST em português para Web/Admin, Mobile/Aluno e Totem."
  },
  "servers": [{ "url": "/api/v1" }],
  "components": {
    "securitySchemes": {
      "bearerAuth": { "type": "http", "scheme": "bearer", "bearerFormat": "JWT" }
    },
    "schemas": {
      "Sucesso": {
        "type": "object",
        "properties": {
          "dados": {},
          "metadados": { "type": "object" }
        }
      },
      "Erro": {
        "type": "object",
        "properties": {
          "erro": {
            "type": "object",
            "properties": {
              "codigo": { "type": "string" },
              "mensagem": { "type": "string" },
              "detalhes": {}
            }
          }
        }
      }
    }
  },
  "security": [{ "bearerAuth": [] }],
  "paths": {
    "/autenticacao/entrar": {
      "post": {
        "summary": "Entrar com identificador e senha",
        "tags": ["Autenticação"],
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "example": { "identificador": "aluno@fatec.sp.gov.br", "senha": "LibCore@123" }
            }
          }
        },
        "responses": { "200": { "description": "Token JWT emitido" } }
      }
    },
    "/autenticacao/validar-rosto": {
      "post": {
        "summary": "Validar reconhecimento facial simulado",
        "tags": ["Autenticação", "Totem"],
        "security": [],
        "requestBody": {
          "content": {
            "application/json": {
              "example": { "facial_token": "facial_mock_123", "id_usuario": 1 }
            }
          }
        },
        "responses": { "200": { "description": "Usuário reconhecido de forma simulada" } }
      }
    },
    "/eu": { "get": { "summary": "Consultar usuário autenticado", "tags": ["Autenticação"], "responses": { "200": { "description": "Sessão atual" } } } },
    "/usuarios": {
      "get": { "summary": "Listar usuários", "tags": ["Web/Admin"] },
      "post": { "summary": "Criar usuário", "tags": ["Web/Admin"] }
    },
    "/livros": {
      "get": { "summary": "Listar livros com filtros busca, categoria e status", "tags": ["Mobile/Aluno", "Web/Admin"] },
      "post": { "summary": "Cadastrar livro", "tags": ["Web/Admin"] }
    },
    "/livros/{id}": {
      "get": { "summary": "Consultar livro", "tags": ["Mobile/Aluno", "Web/Admin"] },
      "patch": { "summary": "Atualizar livro", "tags": ["Web/Admin"] },
      "delete": { "summary": "Remover livro", "tags": ["Web/Admin"] }
    },
    "/livros/rfid/{etiqueta}": {
      "get": { "summary": "Consultar livro pela etiqueta RFID", "tags": ["Totem", "Web/Admin"] }
    },
    "/totem/identificar": { "post": { "summary": "Identificar usuário no totem", "tags": ["Totem"] } },
    "/totem/emprestar": { "post": { "summary": "Registrar empréstimo via RFID", "tags": ["Totem"] } },
    "/totem/devolver": { "post": { "summary": "Registrar devolução via RFID", "tags": ["Totem"] } },
    "/usuarios/meu-token": {
      "get": { "summary": "Consultar token numérico ativo do aluno", "tags": ["Mobile/Aluno"] }
    },
    "/usuarios/meu-token/gerar": {
      "post": { "summary": "Gerar token numérico de 6 dígitos para validação no Mobile Totem Principal", "tags": ["Mobile/Aluno"] }
    },
    "/totem-principal/validar-token": {
      "post": { "summary": "Validar token numérico do aluno no Mobile Totem Principal", "tags": ["Mobile Totem Principal"] }
    },
    "/totem-principal/livro/{etiqueta}": {
      "get": { "summary": "Consultar livro por RFID ou QR mock no Mobile Totem Principal", "tags": ["Mobile Totem Principal"] }
    },
    "/totem-principal/emprestar": {
      "post": { "summary": "Registrar empréstimo com token do aluno e RFID", "tags": ["Mobile Totem Principal"] }
    },
    "/totem-principal/devolver": {
      "post": { "summary": "Registrar devolução com token do aluno e desativar token", "tags": ["Mobile Totem Principal"] }
    },
    "/totem-principal/tickets": {
      "post": { "summary": "Abrir ticket pelo Mobile Totem Principal", "tags": ["Mobile Totem Principal"] }
    },
    "/emprestimos/meus": { "get": { "summary": "Histórico de empréstimos do aluno", "tags": ["Mobile/Aluno"] } },
    "/reservas": {
      "get": { "summary": "Listar reservas do usuário ou todas para admin", "tags": ["Mobile/Aluno", "Web/Admin"] },
      "post": { "summary": "Criar reserva de espaço", "tags": ["Mobile/Aluno"] }
    },
    "/tickets": {
      "get": { "summary": "Listar tickets", "tags": ["Mobile/Aluno", "Web/Admin"] },
      "post": { "summary": "Abrir ticket", "tags": ["Mobile/Aluno", "Totem"] }
    },
    "/notificacoes": { "get": { "summary": "Listar notificações", "tags": ["Mobile/Aluno"] } },
    "/admin/painel": { "get": { "summary": "Resumo administrativo", "tags": ["Web/Admin"] } },
    "/admin/auditoria": { "get": { "summary": "Eventos de auditoria", "tags": ["Web/Admin"] } },
    "/admin/relatorios": { "get": { "summary": "Relatórios consolidados", "tags": ["Web/Admin"] } }
  }
}
